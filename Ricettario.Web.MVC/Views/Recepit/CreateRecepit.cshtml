@using Ricettario.Web.MVC.Models
@model ComponentiRicetta

@{
    ViewData["Title"] = "Crea la tua ricetta";
}

<form method="post" action="/home/createRecepit">
    <div class="mb-3">
        @Html.LabelFor(Model => Model.NomeRicetta, new { @Class = "form-label" })
        @Html.TextBoxFor(Model => Model.NomeRicetta, new { @Class = "form-control", @id = "nomeRicetta" })
    </div>
    <div class="mb-3">
        @Html.LabelFor(Model => Model.Procedimento, new { @Class = "form-label" })
        @Html.TextAreaFor(m => m.procedimento, 3, 0, new { @class = "form-control" })
    </div>
    <div class="row mb-3">
    <div class="col-md-6">
        @Html.LabelFor(m => m.Ingredienti, new { @class = "form-label" })
        @Html.TextBoxFor(m => m.Ingredienti, new { @class = "form-control", id = "ingredienti" })
    </div>

    <div class="col-md-6">
        @Html.LabelFor(m => m.Quantita, new { @class = "form-label" })
        @Html.TextBoxFor(m => m.Quantita, new { @class = "form-control", type = "number" })
    </div>
</div>
    <button type="submit" class="btn btn-primary">Submit</button>
</form>