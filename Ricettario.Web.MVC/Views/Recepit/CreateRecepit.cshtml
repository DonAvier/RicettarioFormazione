@using Ricettario.Web.MVC.Models
@model ComponentiRicetta

@{
    ViewData["Title"] = "Crea la tua ricetta";
}

<form method="post" action="/home/createRecepit">
    <div class="mb-3">
        @Html.LabelFor(Model => Model.NomeRicetta, new { @Class = "form-label" })
        @Html.TextBoxFor(Model => Model.NomeRicetta, new { @Class = "form-control", @id = "nomeRicetta" })
    </div>
    <div class="mb-3">
        @Html.LabelFor(Model => Model.Procedimento, new { @Class = "form-label" })
        @Html.TextBoxFor(Model => Model.Procedimento, new { @Class = "form-control", @id = "procedimento", @rows = "3" })
    </div>
    <div class="mb-3">
        @Html.LabelFor(Model => Model.Ingredienti, new { @Class = "form-label" })
        @Html.TextBoxFor(Model => Model.Ingredienti, new { @Class = "form-control", @id = "ingredienti" })
    </div>
    <button type="submit" class="btn btn-primary">Submit</button>
</form>